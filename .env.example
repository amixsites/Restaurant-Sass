# ============================================================
# Restaurant POS SaaS — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Supabase (Required) ---
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Application Settings ---
# Used by the backend for CORS, redirects, and secure token handling.
FRONTEND_URL=https://your-vercel-app.vercel.app
SECRET_KEY=your_random_secret_string
QR_BASE_URL=https://your-backend.onrender.com

# --- Optional logging / runtime settings ---
ENV=production
LOG_LEVEL=info

# --- WhatsApp Cloud API (Optional — for order notifications) ---
# Found in: Meta Developer Console → WhatsApp → API Setup
# Leave as empty strings to disable WhatsApp features
VITE_WHATSAPP_PHONE_NUMBER_ID=
VITE_WHATSAPP_ACCESS_TOKEN=

# ============================================================
# Vercel Deployment: Add these in Vercel Dashboard →
#   Project → Settings → Environment Variables
# ============================================================
