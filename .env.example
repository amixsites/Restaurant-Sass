# ============================================================
# Restaurant POS SaaS — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Supabase (Required) ---
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Frontend → Backend URL (Required in Production) ---
# This is the URL of your deployed FastAPI backend.
# The Vite dev server proxies /api to localhost:8000, so this is ONLY needed in production.
# Example (Render): https://restaurant-pos-api.onrender.com
# Example (Railway): https://restaurant-pos-api.up.railway.app
VITE_API_URL=https://your-backend.onrender.com

# --- Backend: CORS / Redirect Settings ---
# FRONTEND_URL: The public URL of your deployed frontend (Vercel).
# Supports comma-separated for multiple preview URLs if needed.
# Example: https://restaurant-pos.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# QR_BASE_URL: The PUBLIC URL of your deployed backend.
# This is encoded INTO the QR code image so customers can scan it.
# Must be the same as your backend's public URL (e.g. Render/Railway).
# If not set, falls back to request.base_url (may be wrong behind proxies).
# Example: https://restaurant-pos-api.onrender.com
QR_BASE_URL=https://your-backend.onrender.com

# --- Security ---
SECRET_KEY=your_random_secret_string_at_least_32_chars

# --- Optional Runtime Settings ---
ENV=production
LOG_LEVEL=info

# --- WhatsApp Cloud API (Optional — for order notifications) ---
# Found in: Meta Developer Console → WhatsApp → API Setup
# Leave as empty strings or omit entirely to disable WhatsApp features.
VITE_WHATSAPP_PHONE_NUMBER_ID=
VITE_WHATSAPP_ACCESS_TOKEN=

# ============================================================
# Vercel Deployment Guide:
#   Go to: Vercel → Project → Settings → Environment Variables
#   Add: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_API_URL
#
# Render/Railway Backend Deployment Guide:
#   Add: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY,
#        FRONTEND_URL, QR_BASE_URL, SECRET_KEY, ENV=production
# ============================================================
