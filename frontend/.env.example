# ============================================================
# Restaurant POS SaaS — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Supabase (Required) ---
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Backend API URL (Required for deployed frontend) ---
VITE_API_URL=https://dineinflow.onrender.com

# --- WhatsApp Cloud API (Optional — for order notifications) ---
# Found in: Meta Developer Console → WhatsApp → API Setup
# Leave as empty strings to disable WhatsApp features
VITE_WHATSAPP_PHONE_NUMBER_ID=
VITE_WHATSAPP_ACCESS_TOKEN=

# --- Public App URL (Required for QR code routing) ---
VITE_PUBLIC_APP_URL=http://localhost:5173

# ============================================================
# Vercel Deployment: Add these in Vercel Dashboard →
#   Project → Settings → Environment Variables
# ============================================================

